# ------------------------------
# SudoWork Integration Configuration
# ------------------------------
# Copy to envs/sudowork.env to enable. All values default to disabled — until
# SUDOWORK_INTEGRATION_ENABLED=true the /sudowork blueprint returns 404 on
# every path, exactly matching the inner_api convention.

# Master switch: turns on /sudowork/* routes (SSO + system endpoints).
SUDOWORK_INTEGRATION_ENABLED=false

# HS256 secret used to verify the short-lived JWT carried by the admin browser
# from sudowork-server. MUST match DIFY_SSO_SECRET on the sudowork-server side.
# Generate with: openssl rand -base64 48
SUDOWORK_SSO_SECRET=

# Replay-window for the jti nonce store. 600s is the recommended default.
SUDOWORK_SSO_JTI_TTL_SECONDS=600

# HMAC-SHA256 secret protecting the one-shot /sudowork/system/tenants
# provisioning call. MUST match DIFY_SYSTEM_SECRET on sudowork-server.
SUDOWORK_SYSTEM_SECRET=

# Long-lived bearer accepted on /sudowork/system/* management endpoints.
# MUST match DIFY_SYSTEM_TOKEN on sudowork-server.
SUDOWORK_SYSTEM_TOKEN=

# Optional source-IP allowlist for system endpoints. Comma-separated list of
# IPs or CIDR ranges; empty means no IP check.
SUDOWORK_ALLOWED_IPS=

# Default TenantAccountRole granted to SSO-provisioned admins. Reserved
# values: 'admin' (default), 'editor', 'normal', 'dataset_operator'. 'owner'
# is silently downgraded to 'admin' to keep the system seat unique.
SUDOWORK_DEFAULT_ROLE=admin

# Synthetic email domain used when sudowork-server has no real email for a
# user. Don't point this at a real mail domain you control unless you actively
# expect to receive notifications for these synthetic mailboxes.
SUDOWORK_ACCOUNT_EMAIL_DOMAIN=local.sudowork
